<script>
  import mediumZoom from "medium-zoom";

  type Zoom = import("medium-zoom").Zoom;

  type ArticleImageZoomState = {
    bound: boolean;
    images: HTMLImageElement[];
    zoom: Zoom;
  };

  type ArticleImageZoomWindow = Window & typeof globalThis & {
    __articleImageZoom?: ArticleImageZoomState;
  };

  const ARTICLE_IMAGE_SELECTOR = "#article-content img[data-zoomable]";
  const articleImageZoomWindow = window as ArticleImageZoomWindow;

  const getArticleImageZoomState = () => {
    if (articleImageZoomWindow.__articleImageZoom) {
      return articleImageZoomWindow.__articleImageZoom;
    }

    articleImageZoomWindow.__articleImageZoom = {
      bound: false,
      images: [],
      zoom: mediumZoom({
        background: "rgb(10 10 10 / 0.85)",
        margin: 24,
        scrollOffset: 0,
      }),
    };

    return articleImageZoomWindow.__articleImageZoom;
  };

  const syncArticleImageZoom = () => {
    const state = getArticleImageZoomState();

    if (state.images.length) {
      state.zoom.detach(state.images);
    }

    const images = Array.from(
      document.querySelectorAll<HTMLImageElement>(ARTICLE_IMAGE_SELECTOR),
    );

    state.images = images;

    if (!images.length) {
      return;
    }

    state.zoom.attach(images);
  };

  const initArticleImageZoom = () => {
    const state = getArticleImageZoomState();

    if (!state.bound) {
      document.addEventListener("astro:page-load", syncArticleImageZoom);
      state.bound = true;
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", syncArticleImageZoom, {
        once: true,
      });
      return;
    }

    syncArticleImageZoom();
  };

  initArticleImageZoom();
</script>

<script>
  import mediumZoom from "medium-zoom";

  let zoom: import("medium-zoom").Zoom | undefined;

  const initArticleImageZoom = () => {
    zoom?.detach();

    const images = document.querySelectorAll<HTMLElement>(
      "#article-content [data-zoomable]",
    );

    if (!images.length) {
      return;
    }

    zoom = mediumZoom(images, {
      background: "rgb(10 10 10 / 0.85)",
      margin: 24,
      scrollOffset: 0,
    });
  };

  document.addEventListener("DOMContentLoaded", initArticleImageZoom);
  document.addEventListener("astro:page-load", initArticleImageZoom);
</script>

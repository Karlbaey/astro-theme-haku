---
import { base } from "@/config";

const placeholderText = "搜索文章标题、正文、标签……";
const pagefindPath = `${base}/pagefind/pagefind.js`;
---

<div class="search-modal" aria-hidden="true" data-search-modal>
  <div class="search-modal__backdrop" data-search-close></div>
  <div
    class="search-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="site-search-title"
  >
    <div class="search-modal__header">
      <p id="site-search-title" class="search-modal__title">站内搜索</p>
      <button
        type="button"
        class="search-modal__close"
        aria-label="关闭搜索"
        data-search-close
      >
        <kbd>Esc</kbd> 关闭
      </button>
    </div>
    <input
      class="search-modal__input"
      type="search"
      name="search"
      placeholder={placeholderText}
      autocomplete="off"
      spellcheck="false"
      data-search-input
    />

    <p class="search-modal__status" data-search-status>输入以搜索……</p>

    <div class="search-modal__results" data-search-results></div>
  </div>
</div>

<script is:inline define:vars={{ pagefindPath, base }}>
  (() => {
    const emptyStateMessage = "输入以搜索……";
    const unavailableMessage = "搜索暂时不可用，请先构建站点生成搜索索引。";
    const modal = document.querySelector("[data-search-modal]");
    const input = modal?.querySelector("[data-search-input]");
    const results = modal?.querySelector("[data-search-results]");
    const status = modal?.querySelector("[data-search-status]");
    const openButtons = document.querySelectorAll("[data-search-open]");
    const closeButtons = modal?.querySelectorAll("[data-search-close]") || [];

    if (!modal || !input || !results || !status || !openButtons.length) {
      return;
    }

    let searchApiPromise;
    let searchRequestId = 0;
    let lastFocusedElement = null;

    const escapeHtml = (value) =>
      value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const renderEmptyState = (message) => {
      results.innerHTML = "";
      status.textContent = message;
    };

    const setModalOpen = (open) => {
      modal.setAttribute("aria-hidden", String(!open));
      document.body.classList.toggle("search-open", open);
    };

    const isModalOpen = () => modal.getAttribute("aria-hidden") === "false";

    const normalizeUrl = (url) => {
      if (!url) return "#";
      const normalized = url.startsWith("/") ? url : `/${url}`;
      return `${base}${normalized}`.replace(/\/{2,}/g, "/");
    };

    const loadSearchApi = async () => {
      if (!searchApiPromise) {
        searchApiPromise = import(pagefindPath).then((module) => {
          if (typeof module.options === "function") {
            module.options({ excerptLength: 18 });
          }
          return module;
        });
      }
      return searchApiPromise;
    };

    const closeModal = () => {
      setModalOpen(false);
      if (lastFocusedElement instanceof HTMLElement) {
        lastFocusedElement.focus();
      }
    };

    const openModal = (trigger) => {
      lastFocusedElement =
        trigger instanceof HTMLElement ? trigger : document.activeElement;
      setModalOpen(true);
      window.setTimeout(() => {
        input.focus();
        input.select();
      }, 20);
    };

    const renderResults = (items) => {
      results.innerHTML = items
        .map((item) => {
          const excerpt = item.excerpt || "没有可展示的摘要。";
          const meta = item.meta?.title || item.url;
          return `
            <a class="search-result" href="${normalizeUrl(item.url)}">
              <p class="search-result__title">${escapeHtml(meta)}</p>
              <p class="search-result__excerpt">${excerpt}</p>
            </a>
          `;
        })
        .join("");
    };

    const runSearch = async (keyword) => {
      const query = keyword.trim();
      const requestId = ++searchRequestId;

      if (!query) {
        renderEmptyState(emptyStateMessage);
        return;
      }

      status.textContent = `正在搜索“${query}”……`;

      try {
        const pagefind = await loadSearchApi();
        const search = await pagefind.search(query);

        if (requestId !== searchRequestId) {
          return;
        }

        if (!search?.results?.length) {
          renderEmptyState(`没有找到和“${query}”相关的内容。`);
          return;
        }

        const data = await Promise.all(
          search.results.slice(0, 8).map((item) => item.data()),
        );

        if (requestId !== searchRequestId) {
          return;
        }

        renderResults(data);
        status.textContent = `找到 ${search.results.length} 条结果。`;
      } catch (error) {
        console.error("Search failed:", error);
        renderEmptyState(unavailableMessage);
      }
    };

    openButtons.forEach((button) => {
      button.addEventListener("click", () => openModal(button));
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", closeModal);
    });

    input.addEventListener("input", () => {
      runSearch(input.value);
    });

    results.addEventListener("click", (event) => {
      if (event.target instanceof Element && event.target.closest("a")) {
        closeModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && isModalOpen()) {
        closeModal();
        return;
      }

      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        openModal(document.activeElement);
      }
    });

    renderEmptyState(emptyStateMessage);
  })();
</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: none;
    overflow-y: auto;
    padding: 8vh 1rem 1rem;
  }

  .search-modal[aria-hidden="false"] {
    display: flex;
    justify-content: center;
  }

  .search-modal__backdrop {
    position: absolute;
    inset: 0;
    background: #0a0a0a94;
    backdrop-filter: blur(8px);
  }

  .search-modal__panel {
    position: relative;
    width: min(42rem, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: #f3f2f6;
    box-shadow: 0 24px 80px #0f172a4d;
    max-height: calc(100vh - 9rem);
    display: flex;
    flex-direction: column;
  }

  html.dark .search-modal__panel {
    background: #19181b;
  }

  .search-modal__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .search-modal__title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-readme);
  }

  .search-modal__close {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: #0000;
    color: var(--color-readme);
    cursor: pointer;
    padding: 0.4rem 0.8rem;
    font-size: 0.875rem;
  }

  .search-modal__input {
    margin-top: 1rem;
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    color: var(--color-readme);
    padding: 0.9rem 1rem;
    font-size: 1rem;
    outline: none;
  }

  .search-modal__input:focus {
    border-color: var(--color-readme-anchor);
    box-shadow: 0 0 0 3px #155dfc1f;
  }

  .search-modal__status {
    margin: 0.9rem 0 0;
    min-height: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-tag-text);
  }

  .search-modal__results {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
    min-height: 0;
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 0.5rem 0.85rem 0.75rem;
    border: 1px solid #a8a8a87a;
    border-radius: 1rem;
    overflow-x: hidden;

    scrollbar-width: none;
    -ms-overflow-style: none;

    .search-result {
      display: block;
      padding: 1rem 0.2rem;
      text-decoration: none;
      background: #0000;
      transition:
        background 140ms ease,
        color 140ms ease;
    }

    .search-result + .search-result {
      border-top: 1px solid #a8a8a85c;
    }

    .search-result:hover {
      background: #155dfc12;
      border-radius: 0.75rem;
    }

    .search-result__title {
      margin: 0;
      font-size: 1.16rem;
      font-weight: 750;
      color: var(--color-readme);
      line-height: 1.4;
      letter-spacing: 0.015em;
    }

    .search-result__excerpt {
      color: var(--color-tag-text);
      font-size: 0.86rem;
      line-height: 1.8;
      text-indent: 1.6em;
    }
  }

  .search-modal__results::-webkit-scrollbar {
    display: none;
  }

  html.dark .search-modal__results {
    background: #1a191c;
    border-color: #3a3a3a7a;
    box-shadow: inset 0 1px 0 #FFFFFF0A;

    .search-result + .search-result {
      border-top-color: #3a3a3a5c;
    }

    .search-result:hover {
      background: #2b7fff12;
    }
  }

  :global(body.search-open) {
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .search-modal {
      padding: 1rem;
    }

    .search-modal__panel {
      padding: 0.9rem;
      max-height: calc(100vh - 2rem);
    }

    .search-modal__header {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
